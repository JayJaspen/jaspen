# Supabase - Hämta dessa från ditt Supabase-projekt under Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://DITT-PROJEKT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=din-anon-nyckel-här

# Supabase Service Role - HEMLIGHET, lägg ALDRIG ut denna publikt!
SUPABASE_SERVICE_ROLE_KEY=din-service-role-nyckel-här

# Session-hemlighet - minst 32 tecken långt slumpmässigt lösenord
# Generera t.ex. med: openssl rand -base64 32
SESSION_SECRET=generera-ett-langt-slumpmassigt-losenord-har-minst-32-tecken
